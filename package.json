{
  "name": "meanwaile",
  "productName": "Meanwaile",
  "version": "0.5.0",
  "description": "Menu-bar app that turns AI coding agent dead time and confirmations into the right moment to notify",
  "main": "dist/main.js",
  "author": "Ugaitz Urien",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uurien/meanwaile.git"
  },
  "homepage": "https://github.com/uurien/meanwaile#readme",
  "bugs": {
    "url": "https://github.com/uurien/meanwaile/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "npm run build && MEANWAILE_DEV=1 electron .",
    "watch": "tsc --watch",
    "forge:package": "npm run build && electron-forge package",
    "forge:make": "npm run build && electron-forge make",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.0.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^3.2.7",
    "electron": "^43.1.0",
    "encoding": "^0.1.13",
    "happy-dom": "^20.10.6",
    "typescript": "^5.0.0",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "smol-toml": "^1.7.0"
  }
}
