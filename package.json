{
  "name": "meanwaile",
  "productName": "Meanwaile",
  "version": "0.1.0",
  "description": "Menu-bar app that turns AI coding agent dead time and confirmations into the right moment to notify",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "watch": "tsc --watch",
    "forge:package": "npm run build && electron-forge package",
    "forge:make": "npm run build && electron-forge make",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^36.0.0",
    "encoding": "^0.1.13",
    "happy-dom": "^20.10.6",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
